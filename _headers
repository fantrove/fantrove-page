# whats-new.json: ห้าม cache เด็ดขาด
/assets/json/whats-new.json
  Cache-Control: no-store, no-cache, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

# release-history.json: ห้าม cache
/assets/json/release-history.json
  Cache-Control: no-store, no-cache, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

# current-stage.json: ห้าม cache
/assets/json/current-stage.json
  Cache-Control: no-store, no-cache, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

# assets ทั้งหมด: cache 7 วัน (bust ด้วย ?v= ทุก deploy)
/assets/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Content-Language ตาม URL prefix — ช่วยให้ browser และ search engine
# ตรวจจับภาษาของหน้าได้ถูกต้อง (เพิ่มใน 1.0.8)
/en/*
  Content-Language: en

/th/*
  Content-Language: th

# ทุก path อื่น (HTML ทุกไฟล์ ทุก folder): revalidate ทุกครั้ง
/*
  Cache-Control: no-cache, must-revalidate
