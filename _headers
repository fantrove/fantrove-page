# whats-new.json: ห้าม cache เด็ดขาด
/assets/json/whats-new.json
Cache-Control: no-store, no-cache, max-age=0, must-revalidate
Pragma: no-cache
Expires: 0
Surrogate-Control: no-store

# release-history.json: ห้าม cache
/assets/json/release-history.json
Cache-Control: no-store, no-cache, max-age=0, must-revalidate
Pragma: no-cache
Expires: 0
Surrogate-Control: no-store

# current-stage.json: ห้าม cache
/assets/json/current-stage.json
Cache-Control: no-store, no-cache, max-age=0, must-revalidate
Pragma: no-cache
Expires: 0
Surrogate-Control: no-store

/th/*
Content-Language: th

/en/*
Content-Language: en

# assets ทั้งหมด: cache สูงสุด 1 วัน (bust ด้วย ?v= ทุก deploy)
# (ลดจาก 7 วัน → 1 วัน)
/assets/*
Cache-Control: public, max-age=86400, stale-while-revalidate=86400

# ระบุ /index.html โดยตรงเป็น no-cache (สำคัญสำหรับ SPA ที่ rewrite มาที่ index.html)
/index.html
Cache-Control: no-store, no-cache, max-age=0, must-revalidate
Pragma: no-cache
Expires: 0
Surrogate-Control: no-store

# ทุก path อื่น (HTML ทุกไฟล์ ทุก folder รวมกรณี rewrite): ห้าม cache ทุกกรณี
# วางหลัง /assets/* เพื่อให้กฎ /assets/* ถูกนำไปใช้กับไฟล์ assets ก่อน
/*
Cache-Control: no-store, no-cache, max-age=0, must-revalidate
Pragma: no-cache
Expires: 0
Surrogate-Control: no-store

/*
Content-Encoding: gzip
Vary: Accept-Encoding